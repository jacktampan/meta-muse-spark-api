# Auth/session fallback values.
# Use either MUSE_SPARK_COOKIE_HEADER or MUSE_SPARK_COOKIE.
MUSE_SPARK_COOKIE_HEADER=
MUSE_SPARK_COOKIE=
MUSE_SPARK_AUTHORIZATION=
MUSE_SPARK_MODE=think_fast

# Local API settings.
MUSE_SPARK_MODEL_NAME=meta/muse-spark
MUSE_SPARK_LOG_LEVEL=INFO
# 0 = no artificial chunking (forward provider chunks as-is). Set to a
# positive integer to re-chunk SSE output (rarely needed).
MUSE_SPARK_STREAM_CHUNK_SIZE=0
MUSE_SPARK_DEBUG_FRAME_DUMPS=0
# Idle recv timeout per WebSocket frame. Bump this if responses are getting
# truncated mid-generation (e.g. on slow networks or busy Meta backends).
MUSE_SPARK_RECEIVE_TIMEOUT=30.0
# Sticky conversation mode. Set to 1 so every incoming /v1/chat/completions
# call without an explicit conversation_id reuses one persistent Meta
# conversation. Useful when wiring Muse Spark behind agent frameworks that
# don't pass conversation_id (LangChain, LlamaIndex, OpenAI SDK, ...).
MUSE_SPARK_FORCE_SINGLE_CONVERSATION=0
