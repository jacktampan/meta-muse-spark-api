# Auth/session fallback values.
# Use either MUSE_SPARK_COOKIE_HEADER or MUSE_SPARK_COOKIE.
MUSE_SPARK_COOKIE_HEADER=
MUSE_SPARK_COOKIE=
MUSE_SPARK_AUTHORIZATION=
MUSE_SPARK_MODE=think_fast

# Local API settings.
MUSE_SPARK_MODEL_NAME=meta/muse-spark
MUSE_SPARK_LOG_LEVEL=INFO
# 0 = no artificial chunking (forward provider chunks as-is). Set to a
# positive integer to re-chunk SSE output (rarely needed).
MUSE_SPARK_STREAM_CHUNK_SIZE=0
MUSE_SPARK_DEBUG_FRAME_DUMPS=0
# Idle recv timeout per WebSocket frame. Bump this if Meta is pausing for
# longer than this between tokens — anything over the limit is treated as
# a mid-response stall and the partial output is surfaced with
# finish_reason="length" (graceful truncation). Default 60.0 covers most
# slow/busy backends; raise to 90-120 if your network is congested.
MUSE_SPARK_RECEIVE_TIMEOUT=60.0
# Tighter idle ceiling applied *before* any token has streamed. Healthy Meta
# turns produce the first patch within a couple of seconds, so a multi-second
# silence pre-first-byte is almost always a stuck-conversation symptom (post-
# stall, throttling, or backend wedge). Failing fast here lets the SSE recovery
# path purge + retry sooner instead of holding the client open for the full
# MUSE_SPARK_RECEIVE_TIMEOUT (which is sized for between-tokens slowness, a
# different failure mode). Set to 0 or to MUSE_SPARK_RECEIVE_TIMEOUT to disable.
MUSE_SPARK_FIRST_BYTE_TIMEOUT=20.0
# Sticky conversation mode. Set to 1 so every incoming /v1/chat/completions
# call without an explicit conversation_id reuses one persistent Meta
# conversation. Useful when wiring Muse Spark behind agent frameworks that
# don't pass conversation_id (LangChain, LlamaIndex, OpenAI SDK, ...).
MUSE_SPARK_FORCE_SINGLE_CONVERSATION=0
